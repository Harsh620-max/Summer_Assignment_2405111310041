Reverse Linked List


Given the head of a singly linked list, reverse the list, and return the reversed list.


class Solution {
public:
    
    ListNode* reverseList(ListNode* head){
        ListNode *prev = NULL, *curr = head, *Next = head;
        while(curr){
            Next = curr->next;
            curr->next = prev;
            prev = curr;
            curr = Next;
        }
        return prev;
    }
};
