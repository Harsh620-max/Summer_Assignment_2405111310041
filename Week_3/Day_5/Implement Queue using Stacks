Implement Queue using Stacks

Implement a first in first out (FIFO) queue using only two stacks. 
The implemented queue should support all the functions of a normal queue (push, peek, pop, and empty).


class MyQueue {
public:
    stack<int> st;
    stack<int> helper;
    MyQueue() {
        
    }
    
    void push(int x) {
        st.push(x);
    }
    
    int pop() {
        while(st.size()){
            helper.push(st.top());
            st.pop();
        }
        int ele = helper.top();
        helper.pop();
        while(helper.size()){
            st.push(helper.top());
            helper.pop();
        }
        return ele;
    }
    
    int peek() {
        while(st.size()){
            helper.push(st.top());
            st.pop();
        }
        int ele = helper.top();
        while(helper.size()){
            st.push(helper.top());
            helper.pop();
        }
        return ele; 
    }
    
    bool empty() {
        if(st.size()) return false;
        else return true;
    }
};
