Valid Anagram

Given two strings s and t, return true if t is an anagram of s, and false otherwise.


Method - 1 (without Hashmap)

class Solution {
public:
    bool isAnagram(string s, string t) {
        sort(s.begin(), s.end());
        sort(t.begin(), t.end());

        if(s==t) return true;
        else return false;
    }
};


Method - 2(using Hashmap)

class Solution {
public:
    bool isAnagram(string s, string t) {
        if(s.size() != t.size()) return false;

        unordered_map<char, int> sMap;
        for(char ch : s){
            sMap[ch]++;
        } 

        for(int i=0; i<t.size(); i++){
            char ch = t[i];
            if(sMap.find(ch) == sMap.end()) return false;
            else{
                sMap[ch]--;
                if(sMap[ch] == 0) sMap.erase(ch);
            }
        }
        return true;
    }
};
