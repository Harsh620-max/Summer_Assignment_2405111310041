Move Zeroes

Given an integer array nums, move all 0's to the end of it while maintaining the relative order of the non-zero elements.


class Solution {
public:
    void moveZeroes(vector<int>& arr) {
        int size = arr.size();
        int pos = 0;
        for(int i = 0; i<size; i++){
            if(arr[i]!=0){
                arr[pos] = arr[i];
                pos++;
            }
        }
        for(int i = pos; i<size; i++) arr[i] = 0;
    }
};
